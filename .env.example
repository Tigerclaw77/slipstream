# Public application URL. Use the Vite URL locally and the HTTPS origin in production.
APP_URL=http://127.0.0.1:5173
HOST=127.0.0.1
PORT=4173

# Persistent SQLite file and generated report storage. Mount data/ on a persistent production volume.
DATABASE_PATH=data/slipstream.sqlite
REPORT_OUTPUT_DIR=data/reports

# Stripe Checkout
STRIPE_SECRET_KEY=sk_test_replace_me
STRIPE_WEBHOOK_SECRET=whsec_replace_me
REPORT_PRICE_CENTS=24900

# SMTP delivery
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=replace_me
SMTP_PASS=replace_me
SMTP_FROM=Slipstream SEO <reports@example.com>
SUPPORT_EMAIL=support@example.com

# Customer expectation shown before checkout
DELIVERY_TIMEFRAME=Most reports arrive within 15 minutes.

# Internal dashboard
ADMIN_TOKEN=replace_with_a_long_random_secret

# Fulfillment recovery
QUEUE_CONCURRENCY=2
FULFILLMENT_MAX_ATTEMPTS=3
FULFILLMENT_RETRY_BASE_MS=2000
STUCK_JOB_MINUTES=20

# Analysis and OpenStreetMap identification
ANALYSIS_MODE=live
OSM_USER_AGENT=SlipstreamSEO/1.0 (contact: reports@example.com)
OVERPASS_ENDPOINTS=https://overpass.private.coffee/api/interpreter,https://overpass-api.de/api/interpreter

# Local QA only. Never enable in production.
DEV_BYPASS_PAYMENT=false
