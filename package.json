{
  "name": "slipstream",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently -k -n API,WEB -c yellow,cyan \"npm:dev:server\" \"npm:dev:web\"",
    "dev:server": "tsx watch server/index.ts",
    "dev:web": "vite --host 127.0.0.1",
    "build": "tsc && vite build && tsc -p tsconfig.server.json",
    "preview": "vite preview --host 127.0.0.1",
    "start": "node server-dist/server/index.js",
    "test:smoke": "node scripts/smoke-production.mjs",
    "test:launch": "node scripts/verify-launch.mjs",
    "research:export": "node scripts/export-sales-intelligence.mjs"
  },
  "dependencies": {
    "better-sqlite3": "^12.11.1",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "lucide-react": "^1.24.0",
    "nodemailer": "^9.0.3",
    "pdf-lib": "^1.17.1",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "stripe": "^22.3.1"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/express": "^5.0.6",
    "@types/node": "^26.1.1",
    "@types/nodemailer": "^8.0.1",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^5.0.0",
    "concurrently": "^10.0.3",
    "tsx": "^4.23.1",
    "typescript": "^5.8.3",
    "vite": "^7.0.0"
  }
}
